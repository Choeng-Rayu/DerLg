model Booking {
  id                     String        @id @default(uuid()) @db.Uuid
  bookingRef             String        @unique @map("booking_ref") @db.VarChar(12)
  userId                 String        @map("user_id") @db.Uuid
  tripId                 String?       @map("trip_id") @db.Uuid
  hotelRoomId            String?       @map("hotel_room_id") @db.Uuid
  vehicleId              String?       @map("vehicle_id") @db.Uuid
  guideId                String?       @map("guide_id") @db.Uuid
  status                 BookingStatus @default(PENDING)
  bookingType            BookingType   @map("booking_type")
  travelDate             DateTime      @map("travel_date") @db.Date
  endDate                DateTime?     @map("end_date") @db.Date
  peopleCount            Int           @map("people_count")
  pickupLocation         String?       @map("pickup_location") @db.Text
  specialRequests        String?       @map("special_requests") @db.Text
  customizations         Json?
  subtotalUsd            Decimal       @map("subtotal_usd") @db.Decimal(10, 2)
  discountAmountUsd      Decimal       @default(0) @map("discount_amount_usd") @db.Decimal(10, 2)
  loyaltyDiscountUsd     Decimal       @default(0) @map("loyalty_discount_usd") @db.Decimal(10, 2)
  totalUsd               Decimal       @map("total_usd") @db.Decimal(10, 2)
  loyaltyPointsEarned    Int           @default(0) @map("loyalty_points_earned")
  loyaltyPointsUsed      Int           @default(0) @map("loyalty_points_used")
  studentDiscountApplied Boolean       @default(false) @map("student_discount_applied")
  reservedUntil          DateTime?     @map("reserved_until") @db.Timestamptz
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user                User                   @relation(fields: [userId], references: [id])
  trip                Trip?                  @relation(fields: [tripId], references: [id])
  hotelRoom           HotelRoom?             @relation(fields: [hotelRoomId], references: [id])
  vehicle             TransportationVehicle? @relation(fields: [vehicleId], references: [id])
  guide               Guide?                 @relation(fields: [guideId], references: [id])
  payments            Payment[]
  reviews             Review[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([userId])
  @@index([status])
  @@index([travelDate])
  @@index([bookingRef])
  @@map("bookings")
}
