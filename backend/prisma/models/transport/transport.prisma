model TransportationVehicle {
  id              String          @id @default(uuid()) @db.Uuid
  category        VehicleCategory
  model           String          @db.VarChar
  tier            VehicleTier
  seatCapacity    Int             @map("seat_capacity")
  pricePerDayUsd  Decimal?        @map("price_per_day_usd") @db.Decimal(10, 2)
  pricePerKmUsd   Decimal?        @map("price_per_km_usd") @db.Decimal(8, 4)
  imageUrls       String[]        @map("image_urls")
  features        String[]
  isActive        Boolean         @default(true) @map("is_active")

  // Relations
  bookings        Booking[]

  @@map("transportation_vehicles")
}
