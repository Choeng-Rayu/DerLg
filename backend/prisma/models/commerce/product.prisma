model Trip {
  id                String   @id @default(uuid()) @db.Uuid
  title             String   @db.VarChar(200)
  titleKh           String   @map("title_kh") @db.VarChar(200)
  titleZh           String   @map("title_zh") @db.VarChar(200)
  slug              String   @unique @db.VarChar
  destination       String   @db.VarChar(100)
  durationDays      Int      @map("duration_days")
  pricePerPersonUsd Decimal  @map("price_per_person_usd") @db.Decimal(10, 2)
  environment       Environment
  moodTags          String[] @map("mood_tags")
  includes          Json
  excludes          Json
  itinerary         Json
  highlights        String[]
  minPeople         Int      @map("min_people")
  maxPeople         Int      @map("max_people")
  cancellationPolicy Json    @map("cancellation_policy")
  hotelId           String?  @map("hotel_id") @db.Uuid
  transportType     VehicleCategory @map("transport_type")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  hotel             Hotel?   @relation(fields: [hotelId], references: [id])
  bookings          Booking[]

  @@map("trips")
}



