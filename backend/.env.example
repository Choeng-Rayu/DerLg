# Server
PORT=3001
NODE_ENV=development
APP_STAGE=dev

# Database (Supabase)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase Service (Required for Storage/Auth/Service Role access)
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Redis (Upstash) - Using REST API (HTTP)
UPSTASH_REDIS_REST_URL="https://[endpoint].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Security
JWT_ACCESS_SECRET="your-32-char-min-access-token-secret"
JWT_REFRESH_SECRET="your-32-char-min-refresh-token-secret"
CORS_ORIGINS="*"

# AI Integration
AI_SERVICE_KEY="your-32-char-min-service-key-for-agent"

# Monitoring
SENTRY_DSN=""

# Payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Third Party
RESEND_API_KEY=""
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'
OPENWEATHER_API_KEY=""
EXCHANGE_RATE_API_KEY=""
