# =============================================================================
# AI Agent Service Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# -----------------------------------------------------------------------------
# LLM Backend Configuration
# -----------------------------------------------------------------------------
# Choose which LLM backend to use: "anthropic" or "ollama"
MODEL_BACKEND=anthropic

# Anthropic API Configuration (required when MODEL_BACKEND=anthropic)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama Configuration (required when MODEL_BACKEND=ollama)
# Local Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
# NestJS backend base URL (no trailing slash)
# Development: http://localhost:3001
# Production: https://api.derlg.com
BACKEND_URL=http://localhost:3001

# AI Service Authentication Key (min 32 characters)
# This key is used to authenticate AI agent requests to the backend
# Generate a secure random string: openssl rand -hex 32
AI_SERVICE_KEY=your-secure-32-character-minimum-key-here-change-this-in-production

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Redis connection string for session storage (7-day TTL)
# Local: redis://localhost:6379
# Upstash: redis://default:xxxxx@xxxxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Host to bind the FastAPI server
HOST=0.0.0.0

# Port for the FastAPI server
PORT=8000

# Logging level: debug, info, warning, error, critical
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Error Tracking (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking and monitoring
# Get your DSN from: https://sentry.io/
# Leave empty to disable Sentry
SENTRY_DSN=

# -----------------------------------------------------------------------------
# CORS Configuration (Optional)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Development: http://localhost:3000
# Production: https://derlg.com,https://www.derlg.com
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# WebSocket Configuration (Optional)
# -----------------------------------------------------------------------------
# Maximum number of concurrent WebSocket connections
MAX_CONNECTIONS=1000

# WebSocket ping interval in seconds (keep-alive)
WS_PING_INTERVAL=30

# WebSocket timeout in seconds
WS_TIMEOUT=300
